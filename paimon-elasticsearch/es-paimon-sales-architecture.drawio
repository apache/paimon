          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="old-problem" value="&lt;b&gt;⚠️ 传统方案痛点&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. &lt;b&gt;双重构建成本&lt;/b&gt;：同一份数据需要在 Paimon 和向量库，各构建一次索引，计算 + 存储成本翻倍&lt;br&gt;&lt;br&gt;2. &lt;b&gt;数据同步负担&lt;/b&gt;：需要维护 ETL 链路持续同步数据，一致性难以保证，数据可能产生偏差&lt;br&gt;&lt;br&gt;3. &lt;b&gt;集群常态维护&lt;/b&gt;：即使查询频次不高，Milvus / ES，集群也需要 7×24 运行，持续占用资源和运维精力&lt;br&gt;&lt;br&gt;4. &lt;b&gt;存储冗余&lt;/b&gt;：向量数据在数据湖和向量库各存一份&lt;br&gt;&lt;br&gt;5. &lt;b&gt;标量+向量串行开销&lt;/b&gt;：Paimon 执行标量+向量检索时，需要两阶段串行执行，存在中间结果传输开销&lt;br&gt;&lt;br&gt;6. &lt;b&gt;查询链路耗时高&lt;/b&gt;：通过 Spark / 脚本查询时，需经历资源申请→任务调度→拉起执行→返回结果，整体耗时秒级甚至分钟级" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;fontSize=12;fontFamily=system-ui;align=left;spacingLeft=15;spacingTop=5;" parent="old-box" vertex="1">
          <mxGeometry x="30" y="341" width="750" height="219" as="geometry" />
        </mxCell>
        <mxCell id="new-box" value="&lt;b&gt;✅ Paimon + ES 方案&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=16;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;container=1;collapsible=0;fontFamily=system-ui;" parent="1" vertex="1">
