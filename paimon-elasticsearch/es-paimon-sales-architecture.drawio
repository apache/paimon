        </mxCell>
        <mxCell id="5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;" parent="new-paimon" source="new-idx" target="new-snap" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="new-idx" value="&lt;b&gt;索引文件 (OSS)&lt;/b&gt;&lt;br&gt;ES 格式，构建一次" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontFamily=system-ui;" parent="new-paimon" vertex="1">
          <mxGeometry x="20" y="125" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="new-snap" value="&lt;b&gt;Snapshot 元数据&lt;/b&gt;&lt;br&gt;原子一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontFamily=system-ui;" parent="new-paimon" vertex="1">
          <mxGeometry x="260" y="125" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="new-build-label" value="&lt;b&gt;🔑 构建一次索引&lt;/b&gt;&lt;br&gt;Flink / Spark 分布式构建" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=12;fontFamily=system-ui;" parent="new-paimon" vertex="1">
          <mxGeometry x="100" y="210" width="280" height="45" as="geometry" />
        </mxCell>
        <mxCell id="3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;" parent="new-paimon" source="new-data" target="new-idx" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="new-es" value="&lt;b&gt;ES 集群&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=14;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;container=1;collapsible=0;fontFamily=system-ui;" parent="new-box" vertex="1">
          <mxGeometry x="570" y="50" width="270" height="270" as="geometry" />
        </mxCell>
        <mxCell id="new-import" value="&lt;b&gt;索引元信息导入&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=12;fontFamily=system-ui;" parent="new-es" vertex="1">
          <mxGeometry x="30" y="45" width="210" height="55" as="geometry" />
        </mxCell>
        <mxCell id="new-search" value="&lt;b&gt;多 Shard 并行查询&lt;/b&gt;&lt;br&gt;向量 KNN + 标量过滤&lt;br&gt;毫秒级响应" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#1a73e8;fontSize=12;fontFamily=system-ui;" parent="new-es" vertex="1">
          <mxGeometry x="30" y="120" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="new-openstore" value="&lt;b&gt;OpenStore&lt;/b&gt;&lt;br&gt;直读 OSS 索引文件&lt;br&gt;热数据本地缓存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=12;fontFamily=system-ui;" parent="new-es" vertex="1">
          <mxGeometry x="30" y="200" width="210" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e-new-imp2s" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#F57F17;" parent="new-es" source="new-import" target="new-search" edge="1">
