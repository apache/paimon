        </mxCell>
        <mxCell id="e-new-s2os" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#F57F17;" parent="new-es" source="new-search" target="new-openstore" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="new-query-label" value="&lt;b&gt;多入口查询&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontFamily=system-ui;fontColor=#555555;" parent="new-box" vertex="1">
          <mxGeometry x="30" y="335" width="100" height="25" as="geometry" />
        </mxCell>
        <mxCell id="new-q1" value="Flink SQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=system-ui;" parent="new-box" vertex="1">
          <mxGeometry x="30" y="365" width="110" height="35" as="geometry" />
        </mxCell>
        <mxCell id="new-q2" value="Spark SQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=system-ui;" parent="new-box" vertex="1">
          <mxGeometry x="155" y="365" width="110" height="35" as="geometry" />
        </mxCell>
        <mxCell id="new-q3" value="PyPaimon" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=system-ui;" parent="new-box" vertex="1">
          <mxGeometry x="280" y="365" width="110" height="35" as="geometry" />
        </mxCell>
        <mxCell id="new-q4" value="ES KNN API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=system-ui;" parent="new-box" vertex="1">
          <mxGeometry x="405" y="365" width="110" height="35" as="geometry" />
        </mxCell>
        <mxCell id="new-advantage" value="&lt;b&gt;✅ 方案优势&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. &lt;b&gt;构建一次，双引擎共用&lt;/b&gt;：Paimon 内一次索引构建，同时支持 Paimon 框架查询和 ES 集群查询，节省一半构建成本&lt;br&gt;&lt;br&gt;2. &lt;b&gt;无需数据同步&lt;/b&gt;：ES 直接读 Paimon 的 OSS 存储，无 ETL、无数据搬迁、无一致性问题&lt;br&gt;&lt;br&gt;3. 查询&lt;b&gt;&amp;nbsp;ES 集群提供高性能的并发查询能力&lt;/b&gt;：查询频次不高时无需维护常驻集群，需要在线查询时随时拉起 ES 集群 + 零拷贝挂载，用完释放&lt;br&gt;&lt;br&gt;4. &lt;b&gt;零存储冗余&lt;/b&gt;：数据和索引只在 OSS 上存一份&lt;br&gt;&lt;br&gt;5. &lt;b&gt;标量+向量引擎内联合&lt;/b&gt;：ES Shard 内同步执行标量过滤，和向量搜索，实时剪枝，消除两阶段串行传输开销&lt;br&gt;&lt;br&gt;6. &lt;b&gt;在线服务级延迟&lt;/b&gt;：ES 常驻服务直接响应，无需资源申请、任务调度等批处理流程，毫秒级返回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=12;fontFamily=system-ui;align=left;spacingLeft=15;spacingTop=5;" parent="new-box" vertex="1">
          <mxGeometry x="30" y="420" width="810" height="240" as="geometry" />
        </mxCell>
        <mxCell id="2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="new-box" source="new-snap" target="new-import" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="vs-arrow" value="&lt;b&gt;VS&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=28;fontFamily=system-ui;fontColor=#b85450;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="850" y="300" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="bottom-summary" value="&lt;b&gt;一句话总结：&lt;/b&gt;Paimon 存数据 + 构建索引 → ES 直读 OSS 索引文件 → 按需拉起 ES 集群并行查询 → 不用时释放集群，零额外成本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=15;fontFamily=system-ui;align=center;" parent="1" vertex="1">
          <mxGeometry x="30" y="780" width="1740" height="45" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
